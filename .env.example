# Copy to .env and fill in. Never commit .env.

# ---- Backend (Flask) ----
# Generated via: openssl rand -hex 32
WORLDFORGE_SECRET_KEY=

# Path to the SQLite file. In production this is /data/worldforge.db (mounted volume).
WORLDFORGE_DB_PATH=
# Where JSON auto-backups land. Defaults to sibling 'backups/' of the DB.
WORLDFORGE_BACKUP_DIR=

# Serve-the-SPA-from-Flask override. Production container sets /app/dist.
REBULB_DIST_OVERRIDE=

# Per-IP write limit per minute (default 120). Writes means POST/PUT/DELETE/PATCH.
API_WRITE_RPM=120

# Optional CORS whitelist (only set if frontend is on a different origin).
CORS_ORIGIN=

# App identity (surfaced by /api/health and /api/metrics, tagged on Sentry events)
APP_ENV=development
APP_VERSION=dev

# Error tracking (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Gunicorn tuning (container only)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60

# ---- Frontend (Vite) ----
# Point the SPA at a different API host in dev. Default uses /api (same-origin).
VITE_API_URL=

# Google AdSense — leave blank to render placeholders during dev.
VITE_ADSENSE_CLIENT=
VITE_ADSENSE_AUTO=false
VITE_ADSENSE_SLOT_HOME_TOP=
VITE_ADSENSE_SLOT_HOME_MID=
VITE_ADSENSE_SLOT_DASHBOARD=
VITE_ADSENSE_SLOT_COLLECTION=
VITE_ADSENSE_SLOT_ENTRY=
VITE_ADSENSE_SLOT_SEARCH=
VITE_ADSENSE_SLOT_STICKY=
VITE_DISABLE_ADS=false

# Frontend Sentry (public DSN only)
VITE_SENTRY_DSN=
